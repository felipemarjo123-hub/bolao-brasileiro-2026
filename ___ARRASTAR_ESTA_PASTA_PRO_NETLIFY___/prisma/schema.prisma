generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  bets                 Bet[]
  standings            StandingsBolao?
  roundParticipations  RoundParticipation[]
  staffPayouts         StaffPayout[]

  // Sistema de Afiliados e Pix
  pixKey               String?
  invitedById          String?
  invitedBy            User?        @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers         User[]       @relation("UserInvites")
  createdInvites       InviteCode[] @relation("InviteCreator")
}

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  maxUses     Int      @default(1000)
  currentUses Int      @default(0)
  createdAt   DateTime @default(now())
  
  createdById String?
  creator     User?    @relation("InviteCreator", fields: [createdById], references: [id])
}

model Jackpot {
  id        String   @id @default(cuid())
  type      String   @unique // '6_EXACTOS' ou '10_ACERTOS'
  amount    Float    @default(1000.0)
  updatedAt DateTime @updatedAt
}

model RoundParticipation {
  id        String   @id @default(cuid())
  userId    String
  round     Int
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, round])
}

model StaffPayout {
  id        String   @id @default(cuid())
  userId    String
  round     Int
  isPaid    Boolean  @default(false)
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, round])
}



model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String
  logoUrl   String?
  
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  standing    StandingsChampionship?
}

model Match {
  id          String   @id @default(cuid())
  homeTeamId  String
  awayTeamId  String
  matchDate   DateTime
  homeScore   Int?
  awayScore   Int?
  status      String @default("PENDING")
  round       Int

  homeTeam    Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  bets        Bet[]
}


model Bet {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  homeBetScore  Int
  awayBetScore  Int
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  match         Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model StandingsBolao {
  id             String @id @default(cuid())
  userId         String @unique
  totalPoints    Int    @default(0)
  exactScoreHits Int    @default(0)
  winnerHits     Int    @default(0)
  
  user           User   @relation(fields: [userId], references: [id])
}

model StandingsChampionship {
  id           String @id @default(cuid())
  teamId       String @unique
  points       Int    @default(0)
  wins         Int    @default(0)
  draws        Int    @default(0)
  losses       Int    @default(0)
  goalsFor     Int    @default(0)
  goalsAgainst Int    @default(0)

  team         Team   @relation(fields: [teamId], references: [id])
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
