# Porta em que o servidor irá rodar (injetada automaticamente pelo Railway em produção)
PORT=3000

# URL do Banco de Dados PostgreSQL (injetada automaticamente se provisionada no mesmo projeto Railway)
# Formato esperado: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="PENDENTE: definir"

# Configurações do NextAuth (Autenticação)
# NEXTAUTH_SECRET: Gere um hash aleatório e forte (Ex: openssl rand -base64 32)
NEXTAUTH_SECRET="PENDENTE: definir"

# NEXTAUTH_URL: URL pública do site gerada pelo Railway (Ex: https://bolao.up.railway.app)
NEXTAUTH_URL="PENDENTE: definir"
